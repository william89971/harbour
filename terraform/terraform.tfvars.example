# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
#
# Generate a strong basic auth password with:
#   openssl rand -base64 24

do_token            = "dop_v1_..."
domain              = "harbour.example.com"
letsencrypt_email   = "you@example.com"
basic_auth_user     = "team"
basic_auth_password = "replace-with-openssl-rand-base64-24"

droplet_name  = "harbour"
region        = "sfo3"
size          = "s-2vcpu-4gb"
ssh_key_names = ["your-ssh-key-name-in-do"]

# Optional: lock SSH to your IP only
# ssh_allowed_cidrs = ["1.2.3.4/32"]

# Optional: pin to a specific harbour version
# harbour_ref = "v1.12.0"
